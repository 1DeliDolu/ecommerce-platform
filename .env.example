POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce_user
POSTGRES_PORT=5432
POSTGRES_UID=999

# Postgres password artık secrets/postgres_password.txt dosyasından okunuyor.
# .env içinde POSTGRES_PASSWORD yok — aşağıdaki komutu çalıştır:
#   openssl rand -base64 32 > secrets/postgres_password.txt && chmod 600 secrets/postgres_password.txt

JWT_SECRET=replace_with_a_random_secret_of_at_least_32_bytes
CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_MAIL_FROM=no-reply@enterprise-shop.local
APP_MAIL_ADMIN_TO=admin@example.com

BACKEND_PORT=8080
FRONTEND_PORT=3000
SPRING_PROFILES_ACTIVE=docker

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
