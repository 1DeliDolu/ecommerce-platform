POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce_user
POSTGRES_PORT=5432
POSTGRES_UID=999

# Postgres password artık secrets/postgres_password.txt dosyasından okunuyor.
# .env içinde POSTGRES_PASSWORD yok — aşağıdaki komutu çalıştır:
#   openssl rand -base64 32 > secrets/postgres_password.txt && chmod 600 secrets/postgres_password.txt

# JWT RSA keypair: scripts/dev-up.sh tarafından otomatik oluşturulur.
# Manuel oluşturma:
#   openssl genrsa -out /tmp/jwt.pem 2048
#   openssl pkcs8 -topk8 -nocrypt -in /tmp/jwt.pem -out secrets/jwt_private_key.pem
#   openssl rsa -in /tmp/jwt.pem -pubout -out secrets/jwt_public_key.pem
#   rm /tmp/jwt.pem && chmod 600 secrets/jwt_private_key.pem
JWT_PRIVATE_KEY_PATH=/app/secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=/app/secrets/jwt_public_key.pem

CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_MAIL_FROM=no-reply@enterprise-shop.local
APP_MAIL_ADMIN_TO=admin@example.com

BACKEND_PORT=8080
FRONTEND_PORT=3000
SPRING_PROFILES_ACTIVE=docker

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
