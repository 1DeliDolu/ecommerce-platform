<configuration>
    <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="backend"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}","level":"%level","service":"${serviceName}","correlationId":"%X{correlationId:-}","userId":"%X{userId:-}","action":"%X{action:-}","logger":"%logger{36}","message":"%replace(%msg){'[\r\n\"]','_'}"}%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
